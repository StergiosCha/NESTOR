# NESTOR — environment configuration
# Copy this file to `.env` and fill in the secrets. `.env` is gitignored.

# Azure AI Foundry
# One API key authenticates against both endpoints below (same Azure resource).
AZURE_API_KEY=

# Azure OpenAI Service — used for GPT-family deployments (GPT-4o, GPT-4, ...).
AZURE_OPENAI_ENDPOINT=https://kafouroutsos-8905-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure AI Inference — used for non-OpenAI deployments hosted in Foundry
AZURE_AI_ENDPOINT=https://kafouroutsos-8905-resource.services.ai.azure.com/

# External tools (must be on PATH or absolute paths)
COQC_PATH=coqc
PROVER9_PATH=prover9
MACE4_PATH=mace4

# Pipeline variables
MAX_RETRIES=3          # k for the verification loop (Phase 2 FOL + Coq)
PROVER_TIMEOUT=30      # Prover9/MACE4
COQ_TIMEOUT=60         # coqc
LLM_RATE_LIMIT=0.3     # seconds between LLM calls

# LiteLLM proxy for KriKri (ILSP)
LITELLM_HOST=
LITELLM_ILSP_EVAL_API_KEY=

# Data
FRACAS_XML_URL=https://nlp.stanford.edu/~wcmac/downloads/fracas.xml
